# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved
*.xcodeproj/
*.xcworkspace/

# macOS
.DS_Store

# Xcode
xcuserdata/
DerivedData/
*.moved-aside

# Local env
.env
.env.local

# Acceptance matrix runner output (syslog dumps, etc.)
tmp/

# Build artifacts. `.build/` (SPM) is covered above; these are the Xcode
