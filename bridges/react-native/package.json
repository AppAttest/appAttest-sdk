{
  "name": "@appattest/react-native",
  "version": "0.1.0",
  "description": "React Native bridge for AppAttest — App-Attest-gated secret delivery for iOS.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "ios",
    "!ios/build",
    "*.podspec",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepare": "echo 'use bob in consumers; no prepack step here'"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/__tests__/**/*.test.ts"]
  },
  "keywords": [
    "react-native",
    "ios",
    "app-attest",
    "secrets",
    "keychain"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AppAttest/appAttest-sdk.git",
    "directory": "bridges/react-native"
  },
  "author": "AppAttest",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AppAttest/appAttest-sdk/issues"
  },
  "homepage": "https://github.com/AppAttest/appAttest-sdk/tree/main/bridges/react-native#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.0.0",
    "jest": "^29.7.0",
    "react-native": "^0.77.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "codegenConfig": {
    "name": "RNAppAttestSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {}
  }
}
